rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🚀 플랫폼 관리자 판별 — Sprint 6 A-1: Custom Claims OR 닉네임 화이트리스트 (이중 체크)
    // 운영 절차: A-1(현재) → A-2(Claims 부여 후 검증 2~3일) → A-3(화이트리스트 제거, Claims 단일)
    // Why: ID Token Claims는 서명된 자료라 닉네임 변경 공격 표면 제거.
    //      A-1 단계는 락아웃 방지를 위한 이중 체크 — Claims 미부여 상태로 배포해도 안전.
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.nickname in ['흑무영', 'Admin']);
    }


    // 포럼 콘텐츠 — 비로그인도 읽기 가능 (공개 게시판)
    // 🔒 보안: update/delete는 작성자 본인만 허용 (클라이언트 우회 공격 방지)
    match /posts/{id} {
      allow read: if true;
      // 🔒 보안: 신포도와 여우 카테고리 — 100자 초과 + 이미지 없음 시 서버에서 거부
      // Why: 프론트 우회로 글자수 제한을 무시하는 공격 방지
      // contentTextLength 필드는 클라이언트가 HTML 태그·공백 제거 후 계산한 순수 글자 수
      // content에 '<img ' 포함 시 이미지 첨부로 간주하여 글자수 제한 면제
      // 🏚️ 보안: 유배·귀양지 글은 author 필드가 반드시 "곳간 거주자 #NNNN" 형식이어야 함
      // Why: 클라이언트에서 익명화 로직을 우회하고 실명 닉네임을 저장하는 공격 차단
      //      (STOREHOUSE.md §11.4 — 타인에게 익명으로만 인지)
      allow create: if request.auth != null
        && (request.resource.data.category != '신포도와 여우'
          || request.resource.data.contentTextLength <= 100
          || request.resource.data.content.matches('.*<img .*'))
        && (request.resource.data.category != '유배·귀양지'
          || (request.resource.data.author_id == request.auth.uid
              && request.resource.data.author.matches('^곳간 거주자 #[0-9]{4}$')));
      // 본문 수정·삭제: 작성자 본인만
      allow delete: if request.auth != null
        && resource.data.author_id == request.auth.uid;
      // update: 작성자 본인이거나, 카운터/상태 필드만 변경하는 경우 허용
      // Why: 좋아요·댓글수·조회수·공유수는 타인도 업데이트해야 함
      // 🔒 thanksballTotal 제거(Phase B) — sendThanksball CF(Admin SDK)가 독점 증가, 클라 위조 차단
      allow update: if request.auth != null
        && (resource.data.author_id == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy', 'commentCount', 'viewCount', 'shareCount']));

      // ════════════════════════════════════════════════════════
      // 🖋️ 마르지 않는 잉크병 — 유료 회차 본문 보안 분리
      // ════════════════════════════════════════════════════════
      // 유료 회차의 실제 본문은 posts/{postId}/private_data/content에 저장
      // 읽기: 작가 본인 OR 구매 내역이 있는 유저만 허용
      // 쓰기: 작가 본인만 허용
      // Why: F12 개발자 도구로 유료 본문을 훔쳐보는 것을 방지
      match /private_data/{docId} {
        allow read: if request.auth != null
          && (
            // 작가 본인
            get(/databases/$(database)/documents/posts/$(id)).data.author_id == request.auth.uid
            ||
            // 구매한 유저 (unlocked_episodes 문서 존재 여부 확인)
            exists(/databases/$(database)/documents/unlocked_episodes/$(id + '_' + request.auth.uid))
          );
        // 쓰기: 작가 본인만
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/posts/$(id)).data.author_id == request.auth.uid;
      }

      // 기존 서브컬렉션 (thanksBalls 등) — 읽기만 허용, 쓰기는 CF Admin SDK만
      // Why(Phase E): 클라는 thanksBalls 위조 쓰기가 불필요(CF가 전담) → write false로 공격면 제거
      // ⚠️ private_data는 위에서 별도 match로 처리되므로 여기서 제외됨
      //    Firestore는 더 구체적인 match를 우선 적용함
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /comments/{id} {
      allow read: if true;
      // 🏚️ 보안: 유배·귀양지 글(rootId가 유배글)의 댓글도 author 익명 패턴 강제
      // Why: 댓글도 실명 유출 경로이므로 동일한 방어 필요
      allow create: if request.auth != null
        && (
          // rootId가 없거나(일반 댓글) 혹은 rootId 글이 유배글이 아니면 기본 허용
          !('rootId' in request.resource.data)
          || request.resource.data.rootId == null
          || get(/databases/$(database)/documents/posts/$(request.resource.data.rootId)).data.category != '유배·귀양지'
          // rootId 글이 유배글이면: author_id 본인 + author가 익명 패턴이어야 함
          || (request.resource.data.author_id == request.auth.uid
              && request.resource.data.author.matches('^곳간 거주자 #[0-9]{4}$'))
        );
      // 🖋️ Phase 4-I: 삭제는 작성자 본인 OR 잉크병 회차의 작품 작가
      // (작가는 자기 작품 회차에 달린 다른 사람 댓글을 삭제 가능. 수정은 불가)
      allow delete: if request.auth != null
        && (
          resource.data.author_id == request.auth.uid
          || (
            get(/databases/$(database)/documents/posts/$(resource.data.rootId)).data.category == 'magic_inkwell'
            && get(/databases/$(database)/documents/series/$(get(/databases/$(database)/documents/posts/$(resource.data.rootId)).data.seriesId)).data.authorId == request.auth.uid
          )
        );
      // 수정: 작성자 본인 OR 카운터 필드만 OR 잉크병 회차 작가의 isDeleted 마킹 (Phase 5-C soft delete)
      allow update: if request.auth != null
        && (
          // 작성자 본인 — 전체 수정 가능
          resource.data.author_id == request.auth.uid
          ||
          // 누구나 카운터 필드만 수정
          // 🔒 thanksballTotal 제거(Phase B) — sendThanksball CF(Admin SDK) 전용
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy'])
          ||
          // 🖋️ 잉크병 회차 작가 — isDeleted: true 마킹만 가능 (false 복원/타필드 변경 차단)
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted'])
            && request.resource.data.isDeleted == true
            && get(/databases/$(database)/documents/posts/$(resource.data.rootId)).data.category == 'magic_inkwell'
            && get(/databases/$(database)/documents/series/$(get(/databases/$(database)/documents/posts/$(resource.data.rootId)).data.seriesId)).data.authorId == request.auth.uid
          )
        );
      // 🔒 댓글 서브컬렉션 — 읽기만 허용, 쓰기는 CF Admin SDK만 (Phase E)
      match /{sub=**} { allow read: if true; allow write: if false; }
    }
    match /kanbu_rooms/{id} {
      allow read: if true;
      // 🚪 Creator Gate — 깐부방 신규 개설은 Lv6+ · 크리에이터 점수 0.5+ (잠정, project_creator_gates_tuning.md)
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', 0) >= 6
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('creatorScoreCached', 0) >= 0.5;
      // update/delete: 개설자 포함 멤버 작업, 가입(memberIds arrayUnion) 등 기존 write 허용 유지
      allow update, delete: if request.auth != null;
      match /{sub=**} { allow read: if true; allow write: if request.auth != null; }
    }

    // 🔴 라이브 세션 (Phase 4-A 텍스트 라이브)
    match /live_sessions/{sessionId} {
      allow read: if request.auth != null;
      // 🚪 Creator Gate — 라이브 개설은 Lv6+ · 크리에이터 점수 2.0+ (잠정, project_creator_gates_tuning.md)
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'ready'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', 0) >= 6
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('creatorScoreCached', 0) >= 2.0;
      // 🔒 totalThanksball 제거 — sendThanksball CF(Admin SDK) 전용 (클라 잔액 차감 우회 차단)
      allow update: if request.auth != null
        && (resource.data.hostUid == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeUsers']));
      allow delete: if false;
      match /live_board/{lineId} {
        allow read: if request.auth != null;
        // 🔒 호스트만 보드에 작성 가능
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/live_sessions/$(sessionId)).data.hostUid == request.auth.uid;
        allow update, delete: if false;
      }
      // 🔒 live_chats: sendThanksball CF(Admin SDK) 전용 — 클라 직접 생성 차단
      // Why: VFX 트리거 이벤트를 위조하면 가짜 투척 연출 가능
      match /live_chats/{chatId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      // 🔴 presence: 본인만 자기 문서 쓰기·삭제. Cloud Scheduler가 좀비 정리.
      match /presence/{uid} {
        allow read: if request.auth != null;
        allow write, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 우리들의 장갑 — 커뮤니티 목록은 비로그인도 읽기 가능, 생성/수정은 로그인 필요
    match /communities/{id} {
      allow read: if true;
      allow write: if request.auth != null;
      match /{sub=**} { allow read: if true; allow write: if request.auth != null; }
    }
    // 커뮤니티 멤버십 — 로그인 사용자만 읽기
    // 🔒 Phase 6 보강: verified·joinAnswers 권한 분리, 본인 민감 필드 차단
    // 쓰기 규칙:
    //   create: 본인 명의만 (타인 가입 위조 방지)
    //   update 본인: 탈퇴·닉네임 동기화 허용, 단 verified·finger·joinStatus·banReason 변경 차단
    //   update 타인: thumb/index만, 허용 키(finger·joinStatus·banReason·role·verified)만
    //   delete: 본인 탈퇴 또는 관리자 강퇴
    match /community_memberships/{membershipId} {
      allow read: if request.auth != null;

      // 🔒 create: 본인 명의로만 생성 (타인 가입 위조 방지)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // 본인 멤버십 수정 (탈퇴, 닉네임 동기화)
      // 🔒 차단: verified·finger·joinStatus·banReason은 일반 멤버가 못 바꿈
      // 🛡️ 예외: 방장/부방장(thumb/index)은 자기 verified만 변경 가능 (주주 자기 인증)
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && (
          !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['verified', 'finger', 'joinStatus', 'banReason'])
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verified'])
              && resource.data.finger in ['thumb', 'index'])
        );

      // 본인 멤버십 삭제 (탈퇴)
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // 관리자(thumb/index)에 의한 타인 멤버십 수정 (강퇴·역할변경·승인·인증 부여/해제)
      // 🔒 hasOnly: 허용된 키만 변경 가능 (joinAnswers는 관리자도 수정 불가 — 영구 보존)
      // 🛡️ verifyRequest·reverifyRequestedAt 추가: 주주 인증 요청 상태 관리
      allow update: if request.auth != null
        && resource.data.userId != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['finger', 'joinStatus', 'banReason', 'role', 'verified', 'verifyRequest', 'reverifyRequestedAt'])
        && get(/databases/$(database)/documents/community_memberships/$(resource.data.communityId + '_' + request.auth.uid)).data.finger in ['thumb', 'index'];

      // 관리자에 의한 타인 멤버십 삭제 (강퇴·거절)
      allow delete: if request.auth != null
        && resource.data.userId != request.auth.uid
        && get(/databases/$(database)/documents/community_memberships/$(resource.data.communityId + '_' + request.auth.uid)).data.finger in ['thumb', 'index'];
    }
    // 커뮤니티 게시글 — 비로그인도 읽기 가능, 작성/수정/삭제는 권한 검증
    // 삭제: 작성자 본인 또는 해당 커뮤니티의 thumb/index
    // Why: 악의적 사용자가 클라이언트 우회 후 타인 글 삭제 방지
    match /community_posts/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      // 🔒 보안: 본문 수정은 작성자 본인 또는 관리자(thumb/index)만 허용
      // Why: 좋아요(likes/likedBy)·댓글수(commentCount)·땡스볼(thanksballTotal) 등
      //       카운터 필드는 일반 로그인 사용자도 업데이트해야 하므로, 해당 필드만 별도 허용
      //       isBlinded는 관리자 전용 — 카운터 목록에서 제외하여 관리자 검증을 반드시 거치도록 함
      // 🔒 thanksballTotal 제거(Phase B) — sendThanksball CF(Admin SDK) 전용
      allow update: if request.auth != null
        && (resource.data.author_id == request.auth.uid
          || get(/databases/$(database)/documents/community_memberships/$(resource.data.communityId + '_' + request.auth.uid)).data.finger in ['thumb', 'index']
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy', 'commentCount']));
      allow delete: if request.auth != null
        && (resource.data.author_id == request.auth.uid
          || get(/databases/$(database)/documents/community_memberships/$(resource.data.communityId + '_' + request.auth.uid)).data.finger in ['thumb', 'index']);
      match /{sub=**} { allow read: if true; allow write: if request.auth != null; }
    }

    // 커뮤니티 채팅 — Phase 7 정식 Rules (2026-04-08)
    // 읽기: 로그인 사용자 (멤버 검증은 클라이언트 가드, Rules get() 비용 절약)
    // 생성: 본인 명의만 (author_id == auth.uid)
    // 수정: 본인 메시지만 (soft delete, 이모지 반응은 누구나)
    // 삭제: 금지 (soft delete only)
    match /community_chats/{communityId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.author_id == request.auth.uid;
      // 본인 메시지: deleted 플래그 + 이모지 반응
      // 타인 메시지: 이모지 반응만 (reactions.* 필드)
      // 🔒 thanksballTotal/thanksballSenders 제거(Phase B) — sendThanksball CF(Admin SDK) 전용
      allow update: if request.auth != null
        && (resource.data.author_id == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['reactions']));
      allow delete: if false;
    }

    // 커뮤니티 댓글 — 비로그인도 읽기 가능, 수정·삭제는 작성자 본인만
    match /community_post_comments/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.author_id == request.auth.uid;
    }

    // 거대 나무 — 비로그인도 읽기 가능, 작성자만 수정·삭제
    match /giant_trees/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      // 수정: 작성자 본인 + title/content만 허용
      allow update: if request.auth != null
        && resource.data.author_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'content']);
      // 삭제: 작성자 본인만
      allow delete: if request.auth != null
        && resource.data.author_id == request.auth.uid;
      match /{sub=**} { allow read: if true; allow write: if request.auth != null; }
    }

    // 유저 프로필 — 읽기는 로그인 사용자, 쓰기는 조건부 허용
    // 🔒 보안: 민감 필드(ballBalance·email·nickname 등)는 본인만 수정 가능
    // Why: 좋아요·공유·땡스볼 등에서 타인의 likes·totalShares·ballReceived를 증가시켜야 하므로
    //       전면 차단 대신, 민감 필드 변경 시에만 본인 확인
    // 🛡️ Anti-Abuse Commit 6: exp 가드 + 타인 필드 증가-only + 1회 상한 (ANTI_ABUSE.md §4.2.2)
    match /users/{id} {
      allow read: if request.auth != null;
      // 본인 UID 문서: create 허용
      allow create: if request.auth != null
        && request.auth.uid == id;

      // 🔒 본인 문서 update
      //   (1) ballBalance·프로모 필드 직접 수정 금지 (CF Admin SDK 전용)
      //   (2) 닉네임 필드 직접 수정 금지 (§8 changeNickname CF 전용)
      //   (3) 기득권 필드 직접 수정 금지 (Phase C TUNING_SCHEDULE.md §4)
      //   (4) 🛡️ exp 가드: 증가만, 1회 +100 이하, 음수 불가
      //       Why: F12 콘솔로 exp=99999 직접 수정해 Lv10 달성하는 공격 차단
      //       삭제 시 exp 감소는 Phase B CF 경유로 이관 (§4.4 케이스 2)
      //       → Commit 5a에서 클라 감소 호출 8곳 제거 완료
      //       깐부 해제 시 exp 변동은 Commit 5에서 0으로 수정 완료 (§4.4 케이스 3)
      allow update: if request.auth != null
        && request.auth.uid == id
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'ballBalance',
              'promoEnabled', 'promoExpireAt', 'promoPlan', 'promoUpdatedAt',
              'nickname', 'nicknameChangedAt', 'nicknameChangeCount',
              'previousNicknames',
              'grandfatheredLevel', 'grandfatheredAt',
              // 🛡️ Sprint 3 Phase A — REPUTATION V2 필드 7종 차단
              // Why: F12 콘솔로 reputationCached=99999 직접 쓰기 공격 차단 (CF Admin SDK 전용)
              'reputationCached', 'reputationTierCached', 'reputationUpdatedAt',
              'lastActiveAt', 'abuseFlags', 'grandfatheredPrestigeTier',
              // 🏅 Sprint 4 Phase A — CREATOR SCORE 필드 10종 차단
              // Why: creatorScore·recent30d·likesSent·exileHistory 직접 조작으로 마패/Gate 우회 차단
              'creatorScoreCached', 'creatorScoreTier', 'creatorScoreUpdatedAt',
              'recent30d_posts', 'recent30d_comments', 'recent30d_likesSent',
              'recent30dUpdatedAt', 'reportsUniqueReporters', 'reportsUpdatedAt',
              // 🚨 2026-04-24 신고자 기각 카운트 (rejectReport CF 전용)
              'reportsSubmittedRejected', 'reportsSubmittedRejectedUpdatedAt',
              'likesSent', 'exileHistory',
              // 🔧 Sprint 4 Phase C — 관리자 수동 조정 override (adminAdjustCreatorScore CF 전용)
              'creatorScoreOverride',
              // 🏷️ Sprint 5 — 칭호 시스템 V1 (CF titleAwarder/titleChecker 전용)
              // Why: 자기 업적 위조로 canon 칭호 획득 차단. primaryTitles만 self-write (아래 size<=3 제약).
              'titles', 'validCommentCount', 'ballSentTotal',
              'consecutivePostDays', 'lastPostDate',
              // 📱 Sprint 7 Step 7-A — 휴대폰 인증 필드 (verifyPhoneServer CF 전용)
              // Why: 클라가 phoneVerified=true 임의 세팅 → banned_phones 우회 차단
              'phoneVerified', 'phoneHash', 'phoneVerifiedAt',
              // 📱 Sprint 7 Step 7-C — 추천코드 필드 (generateReferralCode/redeemReferralCode CF 전용)
              // Why: 클라가 referralCode 자가 생성 또는 referralMonthlyCount 조작으로 Rate Limit 우회 차단
              'referralCode', 'referredByCode', 'referredByUid',
              'referralPendingCount', 'referralConfirmedCount',
              'referralMonthKey', 'referralMonthlyCount',
              // 🆔 Sprint 7.5 — 고유번호 (generateUserCode CF 전용, 영구 불변)
              // Why: 클라가 userCode 자가 생성·변경하면 "영구 참조 키" 보장 깨짐
              'userCode',
              // 🗑️ Sprint 7.5 — 회원탈퇴 (requestAccountDeletion/cancelAccountDeletion/purgeDeletedAccounts CF 전용)
              // Why: 클라가 isDeleted=true 임의 세팅 → purge 스케줄로 Auth 자동 삭제되는 사고 차단
              //      deletedAt 임의 과거 세팅 → 30일 유예 우회 차단
              //      nicknameSet 임의 true 세팅 → 닉네임 미설정 상태 통과 차단 (changeNickname CF 전용)
              'isDeleted', 'deletedAt', 'deletionReason', 'nicknameSet',
              // 🚪 Sprint 7.5 핫픽스 — 온보딩 완결 플래그 (completeOnboarding/backfillOnboarding CF 전용)
              // Why: 클라가 onboardingCompleted=true 임의 세팅 → 추천/닉네임/전화 게이트 전부 우회 차단
              'onboardingCompleted', 'onboardingCompletedAt'
            ])
        && (
          !('exp' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.exp is int
            && request.resource.data.exp >= 0
            && request.resource.data.exp >= resource.data.exp
            && request.resource.data.exp - resource.data.exp <= 100
          )
        )
        // 🏷️ Sprint 5 D2-β: primaryTitles 최대 3개 (배열 + 크기 제약). 내용 검증은 CF·클라 모두 수행.
        && (
          !('primaryTitles' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.primaryTitles is list
            && request.resource.data.primaryTitles.size() <= 3
          )
        );

      // nickname_ 접두사 문서: 본인 닉네임 동기화용
      allow create: if request.auth != null
        && id.matches('nickname_.*')
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && id.matches('nickname_.*')
        && resource.data.uid == request.auth.uid;

      // 🛡️ 타인 문서 update: 카운터 증가만 허용
      //   - 감소 차단 (평판 파괴 공격 방지: F12 likes: increment(-3000))
      //     → Commit 5b에서 클라 좋아요 취소 시 users.likes 업데이트 스킵 처리 완료
      //   - 1회 증가 상한 (대량 펌핑 차단: 좋아요 +3, 공유 +1, 프로모뷰 +1)
      //   - ballReceived·ballSpent 제외 (Cloud Function Admin SDK 전용)
      allow update: if request.auth != null
        && request.auth.uid != id
        && !id.matches('nickname_.*')
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'totalShares', 'promoViewCount'])
        && request.resource.data.likes >= resource.data.likes
        && request.resource.data.totalShares >= resource.data.totalShares
        && request.resource.data.promoViewCount >= resource.data.promoViewCount
        && request.resource.data.likes - resource.data.likes <= 3
        && request.resource.data.totalShares - resource.data.totalShares <= 1
        && request.resource.data.promoViewCount - resource.data.promoViewCount <= 1;

      // 관리자: pendingRevenue/pendingThanksBall 원복용 (정산 거절 시)
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pendingRevenue', 'pendingThanksBall']);
    }

    // 알림·내역 — 본인 문서만 읽기/쓰기
    // 🔒 보안: 타인의 알림·내역 접근 차단
    // Why: {nick}은 사용자 UID — 로그인 사용자와 경로의 nick이 일치해야 접근 허용
    // 🔒 알림: 읽기·수정·삭제는 본인만, 생성은 로그인 사용자 누구나
    // Why: 땡스볼·커뮤니티 등에서 타인에게 알림을 보내야 하므로 create만 개방
    match /notifications/{nick}/items/{itemId} {
      allow read: if request.auth != null
        && request.auth.uid == nick;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == nick;
    }
    // 🔒 sentBalls — 읽기는 본인만, 쓰기는 sendThanksball CF(Admin SDK) 전용 (Phase E)
    // Why: 클라가 sentBalls에 가짜 송금 이력을 심어 평판·감사 로그를 흐리는 공격 차단
    match /sentBalls/{nick}/items/{itemId} {
      allow read: if request.auth != null
        && request.auth.uid == nick;
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════
    // 🖋️ 마르지 않는 잉크병 — 연재 시스템 보안 규칙
    // ════════════════════════════════════════════════════════

    // 연재 작품 메타데이터 — 비로그인도 읽기 가능 (작품 목록/상세)
    // 생성: 로그인 + authorId가 본인인지 검증
    // 수정: 작가 본인 OR 카운터 필드(totalViews, totalLikes, subscriberCount)만 변경
    // 삭제: 작가 본인만
    match /series/{seriesId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // 작가 본인: 전체 수정 가능 (제목, 시놉시스, 표지, 무료회차수, 가격 등)
      // 타인: 카운터 필드만 (조회수·좋아요·구독자 수 증감)
      allow update: if request.auth != null
        && (resource.data.authorId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['totalViews', 'totalLikes', 'subscriberCount']));

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // 유료 회차 구매 내역 — 클라이언트 직접 쓰기 금지 (Cloud Functions만)
    // 읽기: 본인 구매 내역만 OR 작가가 자기 작품의 판매 내역 확인
    // 🔒 get은 docId 패턴({postId}_{uid})으로 본인 문서만 허용 (문서 미존재 상태에서도 평가 가능)
    match /unlocked_episodes/{docId} {
      allow get: if request.auth != null
        && docId.matches('.*_' + request.auth.uid + '$');
      allow list: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || resource.data.authorId == request.auth.uid);
      allow write: if false;
    }

    // 🚀 플랫폼 수수료 누적 — 관리자만 읽기, 쓰기는 Cloud Function 전용
    // Why: AdAdminPage의 isAdmin 체크에 더해 Rules 레벨에서도 방어심층화
    match /platform_revenue/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 🔒 예약 닉네임 — 로그인 유저 read (중복 사전 체크용), 쓰기는 CF(changeNickname) 전용
    // Why: ANTI_ABUSE.md §8 — 과거 사용자 닉네임 + 운영 예약어 영구 잠금
    match /reserved_nicknames/{name} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 💰 땡스볼 트랜잭션 멱등키 — Cloud Function 전용 (재시도 이중 차감 차단)
    // Why: sendThanksball이 clientRequestId를 키로 중복 호출을 ball_transactions/{id} 존재 여부로 판별
    match /ball_transactions/{txId} {
      allow read: if false;
      allow write: if false;
    }

    // 🚨 신고 원장 — Cloud Function 전용 (submitReport 호출로만 생성)
    // Why: 클라이언트가 reports 직접 쓰기로 고유 신고자 조작해 타유저 Creator Score 파괴 방지
    //      2026-04-24: 관리자 UI에서 실시간 목록·상태 변경하려면 read 허용 필요
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 🚨 2026-04-24 Phase 4 — 일일 신고 횟수 상한 추적 (submitReport CF 전용)
    // Why: 1인 1일 10건 상한으로 악성 스팸 신고 방어. 클라 read 불필요 (CF가 자체 조회)
    match /reporter_daily_quota/{quotaId} {
      allow read: if false;
      allow write: if false;
    }

    // 🛡️ Sprint 6 A-1: 관리자 행위 감사 로그 — admin_actions
    // read: 관리자만 (운영 이력 열람)
    // write: 전면 차단 (Admin SDK 전용, logAdminAction 헬퍼만 기록)
    match /admin_actions/{actionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════
    // 🏷️ Sprint 5 — 칭호 시스템 V1 (MAPAE_AND_TITLES_V1.md §9)
    // ════════════════════════════════════════════════════════
    // 📖 titles/{titleId} — 마스터 정의 (14종)
    //   read : 전체 공개 (카탈로그·UI 라벨 표시)
    //   write: Admin SDK 전용 (seedTitles CF만)
    match /titles/{titleId} {
      allow read: if true;
      allow write: if false;
    }

    // 🏅 title_achievements/{docId} — 획득 감사 로그
    //   read : 본인(resource.data.uid) OR 관리자
    //   write: Admin SDK 전용 (titleAwarder CF만)
    match /title_achievements/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // 🏳️ title_revocations/{docId} — 회수 이력 (유배·사약 트리거)
    //   read : 본인(resource.data.uid) OR 관리자
    //   write: Admin SDK 전용 (titleRevocation CF만)
    match /title_revocations/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // 🏅 mapae_history/{docId} — 마패 티어 변경 이력 (Creator Score 캐시 변경 훅)
    //   read : 본인(resource.data.uid) OR 관리자
    //   write: Admin SDK 전용 (creatorScoreEvents CF의 mapae 변경 감지만)
    match /mapae_history/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // 💰 땡스볼 잔액 일일 스냅샷 — Cloud Function(snapshotBallBalance) 전용
    // Why: 장부 정합성 검증의 기준점 — 클라 접근 불허, 관리자도 Admin SDK/콘솔로만
    match /ball_balance_snapshots/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // 📜 깐부 홍보 결제 영수증 — Cloud Function(registerKanbuPromo) 전용
    // Why: ball_transactions 원장이 없는 홍보 결제 차감의 감사 크로스체크 권위 — 클라 read 불필요
    match /kanbu_promo_history/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // 💰 감사 이상치 로그 — 관리자 read 전용, 쓰기는 auditBallBalance CF만
    // Why: 잔액 불일치는 보안 이슈 — 관리자 대시보드에서 조회 가능
    match /audit_anomalies/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 🤖 정보봇 결제 이력 — Cloud Function 전용 (대장 본인 조회만 허용)
    match /glove_bot_payments/{docId} {
      allow read: if request.auth != null
        && resource.data.payerUid == request.auth.uid;
      allow write: if false;
    }

    // 🤖 정보봇 중복 방지 — Cloud Function 전용
    match /glove_bot_dedup/{communityId}/items/{hash} {
      allow read: if false;
      allow write: if false;
    }

    // 🤖 DART 종목코드 → 고유번호 매핑 — 로그인 유저 조회 가능, 쓰기는 Cloud Function 전용
    match /dart_corp_map/{stockCode} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════
    // 🏪 강변 시장 (Riverside Market)
    // ════════════════════════════════════════════════════════════

    // 가판대 아이템 — 전체 읽기, 작성자만 수정
    match /market_items/{itemId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.authorId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.authorId;
      allow delete: if false;

      // 본문은 구매자 또는 작성자만 읽기
      match /private_data/content {
        allow read: if request.auth != null
          && (
            request.auth.uid == get(/databases/$(database)/documents/market_items/$(itemId)).data.authorId
            || exists(/databases/$(database)/documents/market_purchases/$(itemId + '_' + request.auth.uid))
          );
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/market_items/$(itemId)).data.authorId;
      }
    }

    // 구매 영수증 — 구매자/판매자만 읽기, 쓰기는 Cloud Function 전용 (리뷰만 구매자 수정 허용)
    match /market_purchases/{purchaseId} {
      allow get: if request.auth != null
        && purchaseId.matches('.*_' + request.auth.uid + '$');
      allow list: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || resource.data.authorId == request.auth.uid);
      allow create: if false;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'review', 'reviewedAt']);
    }

    // 단골장부 상점 — 전체 읽기, 본인만 수정
    match /market_shops/{shopId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.creatorId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.creatorId;
      allow delete: if false;
    }

    // 단골장부 구독 — Cloud Function 전용
    match /market_subscriptions/{subId} {
      allow get: if request.auth != null
        && subId.matches('.*_' + request.auth.uid + '$');
      allow list: if request.auth != null
        && (resource.data.subscriberId == request.auth.uid
          || resource.data.creatorId == request.auth.uid);
      allow create: if false;
      allow update: if false;
    }

    // 광고 수익 — Cloud Function 전용
    match /market_ad_revenues/{recordId} {
      allow read: if request.auth != null
        && resource.data.creatorId == request.auth.uid;
      allow write: if false;
    }

    // 작품 구독 (깐부) — 본인 구독만 관리
    // 복합 ID: {seriesId}_{userId}
    // 🔒 read는 docId 패턴(`*_{uid}`)으로 본인 문서만 허용 (문서 미존재 상태에서도 권한 평가 가능)
    match /series_subscriptions/{docId} {
      allow get: if request.auth != null
        && docId.matches('.*_' + request.auth.uid + '$');
      allow list: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // update 불필요 (구독 on/off는 create/delete로 처리)
      allow update: if false;
    }

    // ════════════════════════════════════════════════════════
    // 🚀 ADSMARKET — 광고 경매 시장 보안 규칙
    // ════════════════════════════════════════════════════════

    // 광고 소재: 누구나 읽기 (노출용), 광고주 본인 + 관리자(검수)
    match /ads/{adId} {
      allow read: if true;
      allow create: if request.auth != null;
      // 본인 또는 관리자(승인/거절) update 허용
      allow update: if request.auth != null
        && (resource.data.advertiserId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null
        && resource.data.advertiserId == request.auth.uid;
    }

    // 광고 이벤트: Cloud Function Admin SDK만 쓰기 (클라이언트 직접 쓰기 금지)
    match /adEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 일일 수익 집계: 본인만 읽기
    match /dailyAdRevenue/{revId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 광고주 계정: 본인만 읽기/쓰기
    match /advertiserAccounts/{advId} {
      allow read, write: if request.auth != null
        && request.auth.uid == advId;
    }

    // 충전 내역: 본인만 읽기
    match /chargeHistory/{chargeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 정산 내역: 본인만 읽기, 관리자만 update (승인/거절/완료)
    match /settlements/{stId} {
      allow read: if request.auth != null;
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    // ════════════════════════════════════════════════════════════
    // 🏚️ 놀부의 텅 빈 곳간 (유배귀양지) — Phase 1
    // ════════════════════════════════════════════════════════════

    // 유배 이력 — 본인만 read, Cloud Function 전용 write
    match /bail_history/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }
    match /release_history/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // 사약 블랙리스트 — 전면 차단 (Cloud Function 전용)
    match /banned_phones/{phoneHash} {
      allow read: if false;
      allow write: if false;
    }

    // 📱 Sprint 7 Step 7-C — 추천코드 카탈로그
    // Why: 가입 시 code lookup이 필요해 read는 로그인 유저에게 공개. write는 CF 전용.
    match /referral_codes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 📱 Sprint 7 Step 7-C — 추천 사용 원장 (멱등 마커)
    // Why: 본인 관련 문서만 열람 (추천자 본인 or 피추천자 본인). write는 CF 전용.
    match /referral_uses/{useId} {
      allow read: if request.auth != null
        && (resource.data.codeOwnerUid == request.auth.uid
            || resource.data.redeemerUid == request.auth.uid);
      allow write: if false;
    }

    // 감사 로그 — 관리자만 read
    match /sanction_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 이의 제기 — 본인 작성/조회, 관리자 모두 조회 + 상태 변경
    match /appeals/{appealId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'adminReply', 'reviewedAt', 'reviewedBy']);
    }

    // 유배지 게시글 — 전체 read (관전), 쓰기는 Cloud Function 전용 (Phase 2에서 확장)
    match /exile_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sanctionStatus in ['exiled_lv1', 'exiled_lv2', 'exiled_lv3'];
      allow update, delete: if false;
    }
    match /exile_comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }
  }
}
